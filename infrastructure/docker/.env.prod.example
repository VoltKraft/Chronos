# Production environment template — copy to .env.prod and fill in real values.
# .env.prod is gitignored; never commit it.

# --- Env flag ---
# Must be set to something other than "dev" in production so the API enforces
# SESSION_SECRET length >= 48 and Shannon entropy >= 4.0 bits/char on startup.
ENV=prod

# --- Postgres ---
POSTGRES_USER=chronos
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=chronos

# --- API ---
# Generate a strong value with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=CHANGE_ME_token_urlsafe_48_bytes
COOKIE_NAME=chronos_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=28800
# H-03: server-side inactivity window (seconds). Reset on every authenticated
# request; expired sessions are cleared and respond 401.
SESSION_IDLE_TIMEOUT_SECONDS=1800
LOG_LEVEL=info

# Login brute-force guard (H-02). Defaults are 5 attempts / 900s lockout.
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_SECONDS=900

# --- Worker ---
JOB_POLL_INTERVAL_SECONDS=15

# --- Traefik / public host ---
# Required: Traefik rejects requests with any other Host header.
PUBLIC_HOST=chronos.example.com

# --- ACME (Let's Encrypt) ---
# Contact address included in ACME registration. Required.
ACME_EMAIL=ops@example.com
# Use the staging CA for rehearsals; switch to production after a successful
# issue. Staging: https://acme-staging-v02.api.letsencrypt.org/directory
#   Prod:         https://acme-v02.api.letsencrypt.org/directory
ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# --- SMTP (optional; enables real email notifications) ---
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=chronos@example.com
SMTP_USE_TLS=true

# --- Public URL used in notification templates and calendar feeds ---
PUBLIC_URL=https://chronos.example.com
