# ⚠️  Example values only — copy to `.env` (prod) or `.env.dev` (dev) and change everything before deploying.

# --- Postgres ---
POSTGRES_USER=chronos
POSTGRES_PASSWORD=chronos_dev_change_me
POSTGRES_DB=chronos

# --- API ---
# DATABASE_URL is assembled inside the compose file from the Postgres vars above.
SESSION_SECRET=change_me_to_a_long_random_string
COOKIE_NAME=chronos_session
# In dev over plain HTTP set COOKIE_SECURE=false; in prod always true.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
SESSION_MAX_AGE_SECONDS=28800
LOG_LEVEL=info

# --- Worker ---
JOB_POLL_INTERVAL_SECONDS=5

# --- Traefik / public host ---
PUBLIC_HOST=chronos.localhost
